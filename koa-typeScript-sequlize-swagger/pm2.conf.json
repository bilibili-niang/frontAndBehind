{
  "apps": [
    {
      "name": "frontHostingServer",
      "cwd": "./",
      "script": "src/main.js",
      "watch": ["src"],
      "ignore_watch": ["node_modules", "logs", ".git", ".idea"],
      "watch_delay": 60000,
      "error_file": "logs/err.log",
      "out_file": "logs/out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "env": {
        "NODE_ENV": "production"
      }
    }
  ]
}