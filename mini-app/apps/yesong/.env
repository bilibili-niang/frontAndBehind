# 环境变量必须以 TARO_APP 开头才能被注入!!!
# 运行时使用变量，必须保证该环境下变量存在，否则可能造成 process is undefined 异常
# 如开发时有需要覆盖某些属性可以添加本地私有配置文件 .env.development.local 防止被 Git 跟踪

#项目名
TARO_APP_NAME=@anteng/yesong
# 微信小程序ID
TARO_APP_ID=wxe94dfe805ea697b2
# 应用场景：yesong
TARO_APP_SCENE=yesong
# 应用来源：yesong
TARO_APP_ORIGIN=1
# 请求域名
TARO_APP_REQUEST_BASE_URL=https://birthday.icestone.work
# 是否直连小程序 true / false
TARO_APP_DIRECT_WEAPP=

# 微信公众号appid

# 移除微信支付能力
TARO_APP_NO_WECHAT_PAY=


TARO_APP_USE_MERCHANT_SMS=true
