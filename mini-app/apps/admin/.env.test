# 管理后台（admin）测试环境变量
# 说明：打包构建（--mode test）会读取此文件，Vite 的 dev 代理不会生效，Axios 将直接使用下列网关地址

# 后端网关地址（优先级最高）
# 示例：https://api-gateway.dev.example.com 或 http://10.0.0.2:3279
VITE_APP_BASE_API=

# 备用后端网关地址（未配置 VITE_APP_BASE_API 时使用）
VITE_APP_REQUEST_BASE_URL=

# 应用场景（可按需设置）
# VITE_APP_SCENE=center

# 应用名称前缀，用于构建后静态资源路径，如 /yesong-admin/
# 与 package.json 的 name 保持一致即可，也可留空
# VITE_APP_NAME=yesong-admin
