# 环境变量配置示例
# 复制此文件为 .env 并填入真实的配置值

# 腾讯地图 API Key
# 申请地址：https://lbs.qq.com/console/mykey.html
VITE_TENCENT_MAP_KEY=

# TinyMCE 富文本编辑器 API Key（可选）
# 申请地址：https://www.tiny.cloud/my-account/dashboard/
# 如果使用自托管版本可以不配置此项
VITE_TINYMCE_API_KEY=your_tinymce_api_key_here

# 其他可能需要的环境变量
# VITE_APP_NAME=admin
# VITE_APP_SCENE=center
# VITE_APP_REQUEST_BASE_URL=https://your-api-domain.com